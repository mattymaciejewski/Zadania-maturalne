#include <iostream>
#include <string>
#include <fstream>
#include <algorithm>
using namespace std;
int main() {
    const int K = 5;
    const int W = 200;
    ifstream plik("anagram.txt");
    ofstream wyniki("wyniki4.txt");
    string tab[K][W];
    for(int i = 0; i < W; i++) {
        for(int j = 0; j < K; j++) {
            plik >> tab[j][i];
        }
    }
    // zadanie 1 
    wyniki << "ZADANIE 1" << endl;
    for(int i = 0; i < W; i++) {
            if(tab[0][i].length() == tab[1][i].length() and tab[1][i].length() == tab[2][i].length() and tab[2][i].length() == tab[3][i].length() and tab[3][i].length() == tab[4][i].length()) {
                for(int j = 0; j < K; j++) {
                    wyniki << tab[j][i] << " ";
                }
            wyniki << endl;
        }
    }
    //zadanie 2
    wyniki << "ZADANIE 2" << endl;
    for(int i = 0; i < W; i++) {
        string a = tab[0][i];
        string b = tab[1][i];
        string c = tab[2][i];
        string d = tab[3][i];
        string e = tab[4][i];
        sort(a.begin(), a.end());
        sort(b.begin(), b.end());
        sort(c.begin(), c.end());
        sort(d.begin(), d.end());
        sort(e.begin(), e.end());
        if(a==b and a==c and a==d and a==e) {
            for(int j = 0; j < K; j++) {
                wyniki << tab[j][i] << " ";
            }
            wyniki << endl;
        }
    }
    return 0;
}
