    int najwieksza = 0;
    for(int i = 0; i < N; i++) {
        string liczba = to_string(tab[i]);
        int dlugosc = liczba.length();
        bool warunek = true;
        for(int j = 1; j < dlugosc; j++) {
            if(liczba[j]<liczba[j-1]) {
                warunek = false;
                break;
            }
        }
        if(warunek) {
