        for(int j = 0; j < dlugosc; j++) {
            int ostatnia = osemkowaLiczba%10;
            dziesietna += ostatnia * pow(8,j);
            osemkowaLiczba /= 10;
        }
        string dziesietnaDoPorownania = to_string(dziesietna);
        dziesietne.push_back(dziesietnaDoPorownania);
        
    }
    for(int i = 0; i < dziesietne.size(); i++) {
        string dziesietna = dziesietne[i];
        int dlugosc = dziesietne[i].length();
