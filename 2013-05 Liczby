            int liczbaSprawdzana = tab[i];
            if(liczbaSprawdzana > najwieksza) {
                najwieksza = tab[i];
            }
            if(liczbaSprawdzana < najmniejsza) {
                najmniejsza = tab[i];
            }
        }
    }
    wyniki << licznikC << endl;
    wyniki << "Najmniejsza = " << najmniejsza << " Najwieksza: " << najwieksza << endl; 
    wyniki.close();
