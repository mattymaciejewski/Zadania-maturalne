using namespace std;
int sumaCyfr(int a) {
    int sc = 0;
    while(a>0) {
        int ostatnia = a%10;
        sc+=ostatnia;
        a/=10;
    }
    return sc;
}
bool czyPierwsza(int a) {
    if(a < 2) {
        return false;
    }
    for(int i = 2; i*i <= a; i++) {
        if(a%i==0) {
            return false;
        }
    }
    return true;
}
bool czyTrPr(int a, int b, int c) {
    if(a>b) {
        swap(a,b);
    }
    if(b>c) {
        swap(b,c);
    }
    if(a>b) {
        swap(a,b);
    }
    if((a*a)+(b*b)==c*c) {
        return true;
    }
    return false;
}
bool czyTrojkat(int a, int b, int c) {
    if(a+b>c&&a+c>b&&b+c>a) {
        return true;
    }
    return false;
}
