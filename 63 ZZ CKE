using namespace std;
bool czyPierwsza(long long int x) {
    if(x<2) {
        return false;
    }
    for(int i = 2; i*i <= x; i++) {
        if(x%i==0) {
            return false;
        }
    }
    return true;
}
bool czyPolpierwsza(long long int x) {
    for(int i = 2; i*i <= x; i++) {
        if(x%i==0) {
        long long int a = i;
        long long int b = x/i;
        if(czyPierwsza(a) and czyPierwsza(b)) {
            return true;
        }
        }
    }
    return false;
}
