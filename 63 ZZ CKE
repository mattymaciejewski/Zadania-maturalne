#include <iostream>
#include <fstream>
#include <vector>
#include <cmath>
#include <algorithm>
using namespace std;
int main() {
    const int N = 1000;
    string tab[N];
    ifstream plik1("ciagi.txt");
    ifstream plik2("liczby2.txt");
    ofstream wyniki("wyniki.txt");
    for(int i = 0; i < N; i++) {
        plik1 >> tab[i];
    }
    wyniki << "1" << endl; 
    int ileDwucyklicznych = 0;
    for(int i = 0; i < N; i++) {
        bool czyDwucykliczny = true;
        string ciag = tab[i];
        int dlugosc = ciag.length();
        if(dlugosc%2!=0) {
            czyDwucykliczny = false;
            continue;
        }
        for(int j = 0;j < dlugosc/2; j++) {
            if(ciag[j]!=ciag[j+(dlugosc/2)]) {
                czyDwucykliczny = false;
            }
        }
        if(czyDwucykliczny) {
            ileDwucyklicznych++;
        }
    }
    wyniki << ileDwucyklicznych << endl;
    wyniki << "2" << endl;
    int ileZJedynkamiObokSiebie = 0;
    int copyN = N;
    for(int i = 0; i < N; i++) {
        string ciag = tab[i];
        int dlugosc = ciag.length();
        bool dwieJedynkiObokSiebie = false;
        for(int j = 1; j < dlugosc; j++) {
            if(ciag[j] == '1' and ciag[j-1] == '1') {
                dwieJedynkiObokSiebie = true;
                break;
            } else {
                dwieJedynkiObokSiebie = false;
            }
        }
        if(dwieJedynkiObokSiebie) {
            ileZJedynkamiObokSiebie++;
        }
    }
    wyniki << copyN - ileZJedynkamiObokSiebie << endl;
}
