#include <iostream>
#include <fstream>
#include <vector>
#include <cmath>
#include <algorithm>
using namespace std;
int osemkowaNaDziesietna(int a) {
    int potega = 1;
    int dziesietna = 0;
    while(a > 0) {
        int ostatnia = a%10;
        dziesietna += ostatnia*potega;
        potega *= 8;
        a/=10;
    }
    return dziesietna;
}
int main() {
    const int N = 1000;
    int osemkowe[N];
    int dziesietne[N];
    ifstream plik1("liczby1.txt");
    ifstream plik2("liczby2.txt");
    ofstream wyniki("wyniki.txt");
    for(int i = 0; i < N; i++) {
        plik1 >> osemkowe[i];
    }
    for(int i = 0; i < N; i++) {
        plik2 >> dziesietne[i];
    }
    wyniki << "1" << endl;
    int max = 0;
    int min = 2000000;
    for(int i = 0; i < N; i++) {
        int liczba = osemkowe[i];
        if(liczba>max) {
            max = liczba;
        }
        if(liczba < min) {
            min = liczba;
        }
    }
    wyniki << max << " " << min << endl;
    wyniki << "2" << endl;
    int najdluzszy = 1;
    int pierwszy = 0;
    int aktualnyPoczatek = 0;
    int seria = 1;
    for(int i = 1; i < N; i++) {
        if(dziesietne[i] >= dziesietne[i-1]) {
            seria++;
        } else {
            seria = 1;
            aktualnyPoczatek = i;
        }
        if(seria > najdluzszy) {
            najdluzszy = seria;
            pierwszy = aktualnyPoczatek;
        }
    }
    wyniki << najdluzszy << " " << dziesietne[pierwszy] << endl;
    wyniki << "3" << endl;
    int takieSame = 0;
    int wieksze = 0;
    for(int i = 0; i < N; i++) {
        if(osemkowaNaDziesietna(osemkowe[i])==dziesietne[i]) {
            takieSame++;
        }
        if(osemkowaNaDziesietna(osemkowe[i]) > dziesietne[i]) {
            wieksze++;
        }
    }
    wyniki << takieSame << " " << wieksze << endl;
}
